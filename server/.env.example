# Copy to server/.env and fill in.

# Postgres connection string.
#  - Supabase: Project Settings -> Database -> Connection string (use the "Session"/direct
#    string for migrations, or the pooled string + ?pgbouncer=true for serverless).
#  - Local Docker (see docker-compose.yml at repo root):
#    postgresql://kelly:kelly@localhost:5432/kellysdeli?schema=public
DATABASE_URL="postgresql://kelly:kelly@localhost:5432/kellysdeli?schema=public"

# Secret used to sign admin JWTs. Use a long random string in production.
JWT_SECRET="dev-secret-change-me"

# API server port.
PORT=4000

# Allowed browser origin for CORS (the Vite dev server).
CLIENT_ORIGIN="http://localhost:5173"

# Seed admin credentials (used by prisma/seed.ts).
ADMIN_EMAIL="owner@kellysdeli.co.uk"
ADMIN_PASSWORD="changeme123"
