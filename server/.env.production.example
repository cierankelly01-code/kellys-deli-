# Production environment for the API. Set these in your host (Vercel / Render) — NEVER commit real values.
NODE_ENV=production

# Supabase Postgres connection string (Project Settings -> Database -> Connection string).
# Use the direct/session string for migrations; the pooled string (?pgbouncer=true) for serverless runtime.
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres"

# Strong random secret — generate with:  openssl rand -hex 32   (or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# The API REFUSES to start in production if this is missing, the dev default, or < 32 chars.
JWT_SECRET="REPLACE_WITH_64_HEX_CHARS"

PORT=4000

# The deployed customer-site origin(s), comma-separated. Used for CORS + referral links.
CLIENT_ORIGIN="https://your-app.vercel.app"

# Seed admin login. The seed REFUSES a weak/default password in production.
ADMIN_EMAIL="owner@kellysdeli.co.uk"
ADMIN_PASSWORD="REPLACE_WITH_A_STRONG_PASSWORD"
